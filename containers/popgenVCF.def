Bootstrap: docker
From: rocker/r-ver:4.5.2

%files
    . /src/popgenVCF

%post
    apt-get update
    apt-get install -y --no-install-recommends libcurl4-openssl-dev libssl-dev libxml2-dev libgit2-dev libfontconfig1-dev libfreetype6-dev libharfbuzz-dev libfribidi-dev libpng-dev libtiff5-dev libjpeg-dev pandoc build-essential
    Rscript -e 'install.packages("BiocManager", repos="https://cloud.r-project.org")'
    Rscript -e 'BiocManager::install(c("SNPRelate","gdsfmt"), ask=FALSE, update=FALSE)'
    Rscript -e 'install.packages("remotes", repos="https://cloud.r-project.org")'
    Rscript -e 'remotes::install_local("/src/popgenVCF", dependencies=TRUE, upgrade="never")'

%runscript
    exec Rscript /usr/local/lib/R/site-library/popgenVCF/scripts/popgenVCF.R "$@"

%labels
    Author Marc-Olivier Duceppe
    Version 0.5.0
